# ===========================================
# DAJANA AI – Svi env placeholderi (jedan fajl)
# Kopiraj: MOBILE APP → dajana-ai-app/.env
#          ADMIN     → dajana-ai-admin/.env.local
# ===========================================

# ========== ŠTA TI TREBA OD STRIPE (sve na stripe.com) ==========
# 1. Nalog: stripe.com → Developers → API keys
# 2. Uključi "Test mode" (prekidač gore desno) za razvoj.
#
# Treba ti 3 stvari:
#   A) Publishable key  → u APP (.env) kao EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY
#      (počinje sa pk_test_ ili pk_live_)
#   B) Secret key      → samo u ADMIN (.env.local) kao STRIPE_SECRET_KEY
#      (počinje sa sk_test_ ili sk_live_) – NIKAD u mobilnoj app
#   C) Webhook secret  → u ADMIN (.env.local) kao STRIPE_WEBHOOK_SECRET
#      Developers → Webhooks → Add endpoint (npr. https://tvoj-domen/api/webhooks/stripe)
#      → nakon kreiranja, "Reveal" Signing secret (whsec_...)
# ===========================================

# ---------- MOBILE APP (dajana-ai-app/.env) ----------
# Baza / auth (obavezno)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Chat (Pitaj Dajanu) i Video (Kreiraj video): idu preko Supabase Edge Functions.
# U app-u NEMA API ključeva – sve je na Supabase:
#   Supabase Dashboard → Edge Functions → Secrets: OPENAI_API_KEY, VIDEO_API_KEY
# Deploy: npx supabase functions deploy chat && npx supabase functions deploy video-start && npx supabase functions deploy video-result
# Try-On (slike): isto preko Edge (GEMINI_API_KEY u Secrets), deploy: generate-try-on

# R2 (Cloudflare) – opciono; ako nije setovan, slike/video idu u Supabase Storage
# Uključi Public access na bucketu u Cloudflare R2 i unesi bazni URL (npr. https://pub-xxx.r2.dev)
EXPO_PUBLIC_R2_PUBLIC_URL=

# Plaćanja (opciono)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=<Stripe publishable key from Dashboard>


# ---------- ADMIN / BACKEND (dajana-ai-admin/.env.local) ----------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

STRIPE_SECRET_KEY=<Stripe secret key from Dashboard – never commit real value>
STRIPE_WEBHOOK_SECRET=<Webhook signing secret after creating endpoint>

# R2 (Cloudflare) – opciono; ako nije setovan, admin upload ide u Supabase Storage
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=dajana-media
# R2_S3_ENDPOINT=https://4df8db7a24ea348b7c55ba8d768855b4.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://pub-xxx.r2.dev
